   "source": [
    "def prob_of_bday_collision(n):\n",
    "    x = 1.0\n",
    "    for i in range(1, n + 1):\n",
    "        x *= 365 - i + 1\n",
    "        x /= 365\n",
    "    \n",
    "    return 1.0 - x\n",
    "\n",
    "for i in (1, 2, 23, 30, 40, 50, 60):\n",
    "    print(i, prob_of_bday_collision(i))"
   ]
